{
  "name": "h-graphic-generator",
  "version": "0.1.0",
  "description": "CLI and MCP server for branded graphic and diagram generation",
  "type": "module",
  "bin": {
    "hgraphic": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "graphics",
    "diagram",
    "mcp",
    "branded",
    "satori",
    "svg",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@mermaid-js/mermaid-cli": "^11.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@resvg/resvg-js": "^2.6.0",
    "commander": "^12.0.0",
    "picocolors": "^1.0.0",
    "puppeteer": "^23.0.0",
    "satori": "^0.12.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.33.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
