{
  "$schema": "h-graphic-component-v1",
  "name": "marketing-typography",
  "description": "Typography styles for marketing graphics",
  "category": "typography",
  "variants": {
    "headline-dark": {
      "color": "gray.50",
      "font": "Inter",
      "fontWeight": 600,
      "fontSize": 85,
      "letterSpacing": "-0.85px"
    },
    "headline-light": {
      "color": "blue.900",
      "font": "Inter",
      "fontWeight": 500,
      "fontSize": 45
    },
    "headline-large": {
      "color": "white",
      "font": "Inter",
      "fontWeight": 600,
      "fontSize": 105,
      "letterSpacing": "1.05px",
      "lineHeight": 1.3
    },
    "subheadline": {
      "color": "gray.500",
      "font": "Inter",
      "fontWeight": 500,
      "fontSize": 55,
      "letterSpacing": "1.1px",
      "lineHeight": 1.3
    },
    "label-dark": {
      "color": "white",
      "font": "Inter",
      "fontWeight": 500,
      "fontSize": 28
    },
    "label-light": {
      "color": "gray.900",
      "font": "Inter",
      "fontWeight": 500,
      "fontSize": 35
    },
    "card-label": {
      "color": "blue.900",
      "font": "Inter",
      "fontWeight": 500,
      "fontSize": 28
    },
    "code-text": {
      "font": "IBM Plex Mono",
      "fontWeight": 500,
      "fontSize": 42,
      "lineHeight": 1.5
    },
    "gradient-text": {
      "description": "Text with gradient fill (e.g., '$300')",
      "technique": "background-clip: text",
      "gradient": "linear-gradient(to bottom, #67f8c7, {{green.600}})",
      "letterSpacing": "-11px for large numbers"
    }
  },
  "ctaButton": {
    "container": {
      "background": "linear-gradient(103deg, {{blue.600}} 15%, {{blue.800}} 109%)",
      "border": "blue.200",
      "borderWidth": 4,
      "borderRadius": 63,
      "height": 96,
      "width": 350
    },
    "text": {
      "color": "white",
      "font": "Inter",
      "fontWeight": 600,
      "fontSize": 44
    }
  }
}
