{
  "$schema": "h-graphic-component-v1",
  "name": "simplified-illustrations",
  "description": "Abstract visual placeholders - not real data",
  "category": "decorative",
  "dataTable": {
    "description": "Simplified table showing structure",
    "background": "white",
    "border": "gray.300",
    "borderWidth": 1.3,
    "borderRadius": 6,
    "header": {
      "background": "white",
      "borderBottom": "gray.300",
      "height": 56,
      "font": "Inter",
      "fontWeight": 500,
      "fontSize": 15
    },
    "dataPlaceholder": {
      "description": "Gray pill shapes representing data values",
      "background": "gray.200",
      "borderRadius": 86,
      "height": 13,
      "width": 75
    },
    "highlightedColumn": {
      "width": 150
    }
  },
  "barChart": {
    "mockup": {
      "colors": ["green.100", "green.300", "green.600", "blue.700"],
      "style": "Simple bars, no axes needed"
    },
    "marketing": {
      "colors": ["blue.800", "blue.700", "blue.600", "blue.500"],
      "borderRadius": 4
    },
    "config": {
      "color": "green.400",
      "borderRadius": 5,
      "width": 54
    }
  },
  "pieChart": {
    "colors": ["green.300", "green.600", "blue.300"],
    "style": "Donut or full pie"
  },
  "lineChart": {
    "strokeColor": "green.500",
    "strokeWidth": 2,
    "style": "Smooth curved line"
  },
  "databaseCylinder": {
    "technique": "SVG ellipses for top/bottom + union shape for body",
    "fill": "rgba(16, 74, 137, 0.3)",
    "stroke": "blue.300"
  },
  "userIcon": {
    "container": {
      "background": "white",
      "borderRadius": 8
    },
    "icon": {
      "colors": ["green.400", "green.600"],
      "style": "gradient silhouette"
    }
  },
  "fileIcon": {
    "description": "Document/file icon (CSV, etc.)",
    "style": "Folded corner, white background",
    "labelColor": "blue.600",
    "size": "large (180px+)"
  },
  "textPlaceholders": {
    "pills": {
      "background": ["#3a689d", "#2e619b", "gray.200"],
      "opacity": 0.5,
      "borderRadius": 12,
      "heights": [18, 20, 30],
      "widths": [96, 120, 179, 262, 457]
    }
  }
}
