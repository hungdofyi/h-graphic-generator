{
  "$schema": "h-graphic-brand-v1",
  "name": "Holistics",
  "colors": {
    "primary": {
      "value": "#05264C",
      "description": "Primary Blue - Dark Blue derived from logo"
    },
    "secondary": {
      "value": "#259B6C",
      "description": "Primary Green - derived from logo"
    },
    "background": {
      "value": "#FFFFFF",
      "description": "Background color"
    },
    "text": {
      "value": "#13151A",
      "description": "Primary text color (Gray-900)"
    },
    "muted": {
      "value": "#8F99A3",
      "description": "Muted/secondary text color (Gray-600)"
    },
    "scales": {
      "green": {
        "50": "#EAF8F2",
        "100": "#CCEDE0",
        "200": "#A4E0C8",
        "300": "#7AD1AE",
        "400": "#52C396",
        "500": "#2CB67F",
        "600": "#259B6C",
        "700": "#1F815A",
        "800": "#196848",
        "900": "#145239"
      },
      "blue": {
        "50": "#E8F2FD",
        "100": "#D1E5FA",
        "200": "#BBD7F7",
        "300": "#8DBEF2",
        "400": "#5EA3ED",
        "500": "#4896EA",
        "600": "#1B7CE4",
        "700": "#1663B6",
        "800": "#104A89",
        "900": "#05264C"
      },
      "gray": {
        "50": "#F9FBFC",
        "100": "#F5F8FA",
        "200": "#EDF1F5",
        "300": "#E3E7ED",
        "400": "#CBD0D7",
        "500": "#B0B6BF",
        "600": "#8F99A3",
        "700": "#4C5159",
        "800": "#2D3238",
        "900": "#13151A"
      }
    },
    "rules": {
      "proportions": {
        "navy": 0.60,
        "green": 0.20,
        "purple": 0.05,
        "blue": 0.05,
        "white": 0.05,
        "gray": 0.05,
        "context": "Landing page / Marketing",
        "note": "Navy (#05264C) dominates backgrounds (60%), green is accent (20%)"
      },
      "gradients": {
        "technique": "Use layered mesh gradients, NOT direct color-to-color blends",
        "meshGradient": {
          "description": "Navy/blue gradient base + blurred green orbs on top",
          "baseColors": ["#05264c", "#104a89", "#052540"],
          "accentOrbs": {
            "colors": ["rgba(37, 155, 108, 0.3)", "rgba(122, 209, 174, 0.25)"],
            "blur": "60-100px",
            "placement": "corners or edges, not center"
          }
        },
        "safeGradients": [
          "blue.900 to blue.700 (within same family)",
          "green.400 to green.600 (within same family)",
          "gray.100 to white (subtle)"
        ],
        "avoid": [
          "Direct green-to-navy linear gradients (harsh transition)",
          "Primary green (#259B6C) directly blending to navy (#05264C)",
          "High saturation color stops without blur/softening"
        ]
      },
      "avoid": [
        "Low contrast pairings (e.g. blue text on green background)",
        "Harsh gradients between green and navy",
        "Direct linear-gradient from green to navy without softening",
        "Green-to-navy gradient as background (use mesh gradient instead)"
      ],
      "unsuccessfulExamples": [
        {
          "description": "Blue text on green background",
          "reason": "Don't provide enough contrast"
        },
        {
          "description": "Green-to-navy linear gradient background",
          "reason": "Gradient too harsh"
        }
      ]
    }
  },
  "typography": {
    "fonts": {
      "primary": "Inter",
      "code": "JetBrains Mono",
      "logo": "Museo Sans"
    },
    "weights": {
      "regular": "400",
      "medium": "500",
      "semiBold": "600",
      "bold": "700"
    },
    "scales": {
      "display": {
        "size": 48,
        "weight": "700",
        "lineHeight": "120%",
        "letterSpacing": "0%"
      },
      "title": {
        "size": 42,
        "weight": "700",
        "lineHeight": "120%",
        "letterSpacing": "0%"
      },
      "subtitle1": {
        "size": 32,
        "weight": "600",
        "lineHeight": "120%",
        "letterSpacing": "0%"
      },
      "subtitle2": {
        "size": 28,
        "weight": "700",
        "lineHeight": "120%",
        "letterSpacing": "0%"
      },
      "subtitle3": {
        "size": 24,
        "weight": "700",
        "lineHeight": "140%",
        "letterSpacing": "0%"
      },
      "subtitle4": {
        "size": 20,
        "weight": "600",
        "lineHeight": "140%",
        "letterSpacing": "0%"
      },
      "body": {
        "size": 20,
        "weight": "400",
        "lineHeight": "160%",
        "letterSpacing": "0%"
      },
      "microTitle": {
        "size": 16,
        "weight": "700",
        "lineHeight": "160%",
        "letterSpacing": "0%"
      },
      "default": {
        "size": 16,
        "weight": "400",
        "lineHeight": "160%",
        "letterSpacing": "0%"
      },
      "small": {
        "size": 14,
        "weight": "400",
        "lineHeight": "160%",
        "letterSpacing": "0%"
      },
      "tiny": {
        "size": 12,
        "weight": "400",
        "lineHeight": "160%",
        "letterSpacing": "0%"
      }
    },
    "rules": {
      "desktop": {
        "charsPerLine": { "min": 50, "max": 75 }
      },
      "mobile": {
        "charsPerLine": { "min": 30, "max": 50 }
      },
      "paragraphSpacing": {
        "min": "50%",
        "max": "100%",
        "relativeTo": "bodyTextSize"
      },
      "avoid": [
        "Pairing too many fonts (stick to Inter + JetBrains Mono)",
        "Orphan text (single word at paragraph bottom)",
        "Line height too narrow",
        "Line height and letter spacing too wide",
        "Script/handwriting fonts",
        "Italic fonts for body text"
      ]
    }
  },
  "logo": {
    "elements": ["icon", "wordmark"],
    "logomarkUsage": ["app icons", "web favicons", "buttons", "social media avatars", "decorative accents"],
    "files": {
      "primary": "data/Logo Color.svg",
      "primaryDark": "data/Logo Dark.svg",
      "primaryLight": "data/Logo Light.svg",
      "altDark": "data/Logo Alt Dark.svg",
      "altLight": "data/Logo Alt Light.svg",
      "logomarkColor": "data/Logomark - Color - Light BG.svg",
      "logomarkColorDark": "data/Logomark - Color - Dark BG.svg",
      "logomarkDark": "data/Logomark - Dark - Transpanrent.svg",
      "logomarkLight": "data/Logomark - Light - Transpanrent.svg"
    },
    "usage": {
      "onWhite": "Use Logo Color.svg or Logomark - Color - Light BG.svg",
      "onNavy": "Use Logo Light.svg or Logomark - Light - Transpanrent.svg",
      "onGreen": "Use Logo Light.svg or Logomark - Light - Transpanrent.svg",
      "decorative": "Logomark only, positioned in corners as accent"
    },
    "rules": {
      "lockup": "Symbol and wordmark should exist together when possible",
      "clearSpace": {
        "unit": "capHeight of 'o' letter",
        "description": "Clear space around logo equals cap height and width of 'o' letter"
      },
      "partners": {
        "spacing": "Clear space between logos using 'o' width",
        "height": "Partnership logos font height should extend to line top of 'h'"
      },
      "propertyLogo": {
        "typeface": "Museo Sans",
        "weight": "500",
        "examples": ["blog", "playground", "docs", "community"]
      },
      "avoid": [
        "Reposition elements",
        "Scale marks disproportionately",
        "Alter the color of marks",
        "Resize elements individually",
        "Use wordmark alone",
        "Change the typeface of wordmark"
      ]
    },
    "variants": {
      "primaryColor": "Default version with brand colors",
      "primaryBlue": "Blue lockup",
      "primaryWhiteOnGreen": "White logo on green background",
      "primaryWhiteOnBlue": "White logo on blue background",
      "primaryGreenWhite": "Green and white lockup"
    }
  },
  "illustration": {
    "purpose": "Simplify complex ideas and support storytelling across marketing touchpoints",
    "should": [
      "Reflect the user's context and emotional state",
      "Represent brand personality and voice effectively",
      "Support, not overshadow, the key message",
      "Have a clear purpose beyond mere decoration"
    ],
    "types": {
      "hero": {
        "description": "For larger areas like landing page hero banners - full scenes",
        "background": "Navy mesh gradient (navy base + soft green/blue orbs)",
        "content": "Dashboard mockups, layered UI elements, product screenshots"
      },
      "spot": {
        "description": "More elements than icons, but not full scenes like hero",
        "background": "Green/teal gradient or solid light backgrounds",
        "content": "Simplified UI elements, single feature focus"
      },
      "icon": {
        "description": "Minimal, informed by round corners and medium stroke from logo",
        "style": "Round corners, medium stroke weight"
      }
    },
    "principles": {
      "innovative": "Showcasing brand's dynamic nature, reflecting proactive approach to staying ahead",
      "straightforward": "Clear hierarchies and organized layouts for clear, reliable messaging",
      "delightful": "Blend delightful touches and thoughtful considerations to connect emotionally",
      "modular": "Utilize reusable components to maintain brand cohesion across channels"
    },
    "usage": {
      "marketing": ["websites", "landing pages", "presentations", "social media", "video"],
      "product": ["empty state", "onboarding", "educational content"]
    },
    "iconography": {
      "style": "Round corners and medium stroke, informed by logo",
      "sizing": {
        "note": "Icons are SVG - scale to ANY size needed",
        "small": "16-24px for UI/inline",
        "medium": "32-64px for features",
        "large": "80-200px for hero/decorative",
        "noRestriction": true
      },
      "library": "brand/data/icons/",
      "emojiRule": {
        "IMPORTANT": "NEVER use OS/system emojis (🔒📊💡 etc.) - they look inconsistent",
        "alternative": [
          "1. First: Search brand/data/icons/ for a matching icon",
          "2. If not found + simple need: Create simple SVG icon (round corners, medium stroke, brand colors)",
          "3. If not found + complex/styled need: Create spot illustration with gradients, shadows, brand styling"
        ]
      }
    }
  },
  "spacing": {
    "unit": 8,
    "scales": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32,
      "2xl": 48
    }
  },
  "assets": {
    "logo": "data/Logo Color.svg",
    "logoDark": "data/Logo Dark.svg",
    "logoLight": "data/Logo Light.svg",
    "logoAltDark": "data/Logo Alt Dark.svg",
    "logoAltLight": "data/Logo Alt Light.svg",
    "icon": "data/Logomark - Color - Light BG.svg",
    "iconDark": "data/Logomark - Dark - Transpanrent.svg",
    "iconLight": "data/Logomark - Light - Transpanrent.svg"
  },
  "diagram": {
    "nodeColors": {
      "default": "#EAF8F2",
      "accent": "#E8F2FD"
    },
    "edgeColor": "#8F99A3",
    "borderRadius": 8
  },
  "highlightGuidelines": {
    "borders": {
      "maxWidth": "2px",
      "structural": "1px - for containment (cards, regions)",
      "emphasis": "1.5-2px - for highlight/selected states",
      "avoid": "3px+ borders look dated and harsh"
    },
    "byBackground": {
      "dark": {
        "prefer": "Color glows (box-shadow with color)",
        "examples": [
          "box-shadow: 0 0 0 1px #52c396, 0 0 20px rgba(44, 182, 127, 0.3)",
          "box-shadow: 0 0 32px rgba(122, 209, 174, 0.2)"
        ],
        "why": "Glows emit 'light' - pop well against dark backgrounds"
      },
      "light": {
        "prefer": "Elevation shadows + background tints",
        "examples": [
          "box-shadow: 0 4px 16px rgba(19, 21, 26, 0.1)",
          "background: linear-gradient(135deg, #eaf8f2, #fff)",
          "border: 1.5px solid #52c396; box-shadow: 0 4px 12px rgba(19, 21, 26, 0.08)"
        ],
        "why": "Glows wash out on light - shadows create depth instead"
      }
    },
    "bestPractice": {
      "combine": "Thin border (1-2px) + shadow for best results",
      "avoid": [
        "Thick borders (3px+) as sole emphasis method",
        "Color glows on light backgrounds",
        "Multiple heavy effects stacked"
      ]
    }
  },

  "graphicElements": {
    "arrows": {
      "IMPORTANT": "DO NOT use text arrows (→, >, ➜). Use CSS-drawn connectors.",
      "horizontal": {
        "html": "<div style=\"display:flex;align-items:center;\"><div style=\"width:40px;height:2px;background:#8f99a3;\"></div><div style=\"width:0;height:0;border-top:6px solid transparent;border-bottom:6px solid transparent;border-left:8px solid #8f99a3;\"></div></div>",
        "description": "Line + CSS triangle arrowhead"
      },
      "vertical": {
        "html": "<div style=\"display:flex;flex-direction:column;align-items:center;\"><div style=\"width:2px;height:40px;background:#8f99a3;\"></div><div style=\"width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-top:8px solid #8f99a3;\"></div></div>",
        "description": "Vertical line + downward arrowhead"
      },
      "colors": {
        "default": "#8f99a3",
        "green": "#259b6c",
        "navy": "#05264c"
      }
    },
    "backgrounds": {
      "navy": {
        "solid": "#05264C",
        "note": "Use solid navy for dark backgrounds, NOT lighter blues"
      },
      "white": "#FFFFFF",
      "lightGray": "#F9FBFC",
      "lightBlue": "#E8F2FD",
      "lightGreen": "#EAF8F2"
    },
    "backgroundUsage": {
      "default": "Navy mesh gradient for marketing/hero graphics",
      "onRequest": "Respect user's background choice (white, light, etc.)",
      "documentation": "White or light gray backgrounds preferred",
      "inApp": "White or light backgrounds"
    },
    "complexShapes": {
      "cylinder": {
        "reference": "brand/extracted/svg-templates/icon-data-warehouse.svg",
        "note": "When drawing CSS cylinders, ensure body width is narrower than ellipse to account for border curves",
        "avoid": "Body edges extending past ellipse edges"
      }
    }
  }
}
