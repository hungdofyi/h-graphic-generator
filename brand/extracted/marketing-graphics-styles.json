    "meshGreenBlue": {
      "name": "Mesh Green-Blue (Layered)",
      "description": "Navy base with blurred green orbs on top - NOT a direct green-to-navy gradient",
      "technique": "layered",
      "baseGradient": {
        "colors": ["#05264c (navy/blue-900)", "#104a89 (blue-800)", "#052540 (darker navy)"],
        "rules": {
          "navyDominance": "Navy (#05264c) should cover 60-80% of the gradient",
          "lighterAccent": "Blue-800 (#104a89) as subtle highlight, 20-40% max",
          "angles": "Use 130-160deg for diagonal flow"
        },
        "examples": [
          "linear-gradient(145deg, #05264c 0%, #104a89 60%, #05264c 100%)",
          "linear-gradient(135deg, #05264c 0%, #05264c 50%, #104a89 80%, #052540 100%)",
          "linear-gradient(160deg, #052540 0%, #05264c 30%, #104a89 70%, #05264c 100%)",
          "radial-gradient(ellipse at 30% 70%, #104a89 0%, #05264c 60%)"
        ]
      },
      "greenOrbs": {
        "purpose": "Add soft green accents as blurred overlays, NOT in the base gradient",
        "colors": ["rgba(37, 155, 108, 0.3-0.5)", "rgba(122, 209, 174, 0.2-0.35)"],
        "blur": "60-120px",
        "placement": "Corners or edges, avoid center",
        "size": "200-500px ellipses"
      },
      "avoid": [
        "Direct green-to-navy linear gradient",
        "Green taking more than 30% of visible area",
        "Sharp color transitions without blur"
      ],
      "usage": ["hero sections", "feature showcases", "premium announcements"]
    },
