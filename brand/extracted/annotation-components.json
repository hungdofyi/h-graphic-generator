{
  "$schema": "h-graphic-extracted-v1",
  "extractedAt": "2026-03-09T12:00:00+07:00",
  "description": "Reusable annotation and explainer components extracted from Figma docs-explainer frames",
  "sourceFrames": [
    { "name": "Embed Portal Mechanism", "nodeId": "1:1963" },
    { "name": "Embed Portal's Data Permission (v2)", "nodeId": "1:2159" }
  ],

  "connectionLines": {
    "description": "Curved and straight connectors showing data/control flow between elements",
    "patterns": {
      "straightHorizontal": {
        "css": {
          "width": "var(--length, 100px)",
          "height": "2px",
          "background": "var(--color, {{gray.600}})"
        },
        "usage": "Simple horizontal connections"
      },
      "straightVertical": {
        "css": {
          "width": "2px",
          "height": "var(--length, 100px)",
          "background": "var(--color, {{gray.600}})"
        },
        "usage": "Simple vertical connections"
      },
      "curvedSingleBend": {
        "svg": "svg-templates/explainer-flow-connector-l-shape.svg",
        "description": "L-shaped connector with rounded corner",
        "customizable": ["stroke", "strokeWidth"],
        "usage": "Connect elements at right angles"
      },
      "curvedMultiPath": {
        "description": "Complex curved paths connecting multiple elements",
        "svgFiles": [
          "svg-templates/explainer-flow-path-curved.svg",
          "svg-templates/explainer-flow-path-large.svg"
        ],
        "usage": "Multi-segment flows (embed → backend → frontend)"
      },
      "branchConnector": {
        "description": "One-to-many or many-to-one connections",
        "svgFiles": [
          "svg-templates/explainer-branch-connector-left.svg",
          "svg-templates/explainer-branch-connector-right.svg"
        ],
        "usage": "Merge/split visualizations, data filtering branches"
      }
    },
    "connectionDots": {
      "description": "Small dots marking connection points on lines",
      "sizes": {
        "small": 6,
        "default": 8,
        "large": 10
      },
      "colors": {
        "green": "green.600",
        "blue": "blue.600",
        "purple": "purple.600",
        "gray": "gray.600"
      },
      "svgFiles": {
        "green": "svg-templates/explainer-dot-green.svg",
        "greenLarge": "svg-templates/explainer-dot-green-large.svg",
        "blue": "svg-templates/explainer-dot-blue.svg",
        "blueLarge": "svg-templates/explainer-dot-blue-large.svg",
        "purple": "svg-templates/explainer-dot-purple.svg"
      }
    },
    "arrowStyles": {
      "standard": {
        "strokeWidth": 2,
        "strokeColor": "gray.600",
        "arrowheadSize": 8
      },
      "emphasized": {
        "strokeWidth": 2.5,
        "strokeColor": "green.600",
        "arrowheadSize": 10
      }
    }
  },

  "stepIndicators": {
    "description": "Numbered circles indicating sequence steps",
    "primary": {
      "size": 25,
