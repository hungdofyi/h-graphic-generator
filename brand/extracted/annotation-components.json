      "fontWeight": 600,
      "fontSize": 15,
      "usage": "Main step numbers (1, 2, 3, 4, 5)"
    },
    "subStep": {
      "size": 25,
      "borderRadius": "50%",
      "background": "green.600",
      "textColor": "white",
      "font": "Inter",
      "fontWeight": 600,
      "fontSize": 13,
      "usage": "Sub-step numbers (3.1, 3.2)"
    },
    "variants": {
      "blue": { "background": "blue.600" },
      "purple": { "background": "purple.600" }
    },
    "svgTemplate": "svg-templates/explainer-step-circle.svg"
  },

  "containers": {
    "description": "Box styles for grouping related content",
