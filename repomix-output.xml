 */
export function registerListTemplatesTool(server: McpServer): void {
  server.tool(
    'list_templates',
    'List available templates for generate_from_template tool',
    ListTemplatesSchema.shape,
    async (args) => {
      const input = ListTemplatesSchema.parse(args);

